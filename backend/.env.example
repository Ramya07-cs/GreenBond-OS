# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values (Alchemy, MetaMask, Twilio, SendGrid)

# ── DATABASE ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://greenbond:password@localhost:5432/greenbonds

# ── REDIS ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# ── APP ───────────────────────────────────────────────────────────────────────
# Generate SECRET_KEY by running:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-key-with-the-command-above
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── BLOCKCHAIN (Polygon Amoy Testnet) ─────────────────────────────────────────
# WALLET_PRIVATE_KEY — MetaMask → Account Details → Export Private Key
# Keep a test wallet funded with testnet MATIC (free from https://faucet.polygon.technology/).
# POLYGON_RPC_URL — from Alchemy: https://dashboard.alchemy.com
# CONTRACT_ADDRESS — set after you deploy GreenBond.sol via Hardhat/Remix

POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
WALLET_PRIVATE_KEY=0xYOUR_METAMASK_PRIVATE_KEY
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── NASA POWER API ────────────────────────────────────────────────────────────

NASA_API_BASE=https://power.larc.nasa.gov/api/temporal/daily/point
NASA_COMMUNITY=RE
NASA_PARAMETER=ALLSKY_SFC_SW_DWN

# ── TWILIO (SMS alerts) ───────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── SENDGRID (Email alerts) ───────────────────────────────────────────────────

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── CELERY BEAT SCHEDULE ──────────────────────────────────────────────────────

CELERY_TIMEZONE=Asia/Kolkata
AUDIT_CRON_HOUR=6
AUDIT_CRON_MINUTE=0

# ── PR ENGINE ─────────────────────────────────────────────────────────────────
PR_THRESHOLD=0.75
CONSECUTIVE_PENALTY_DAYS=3
CONSECUTIVE_RECOVERY_DAYS=7
PERFORMANCE_FACTOR=0.80
PENALTY_RATE_MULTIPLIER=1.5

# ── SENTRY (error monitoring — leave blank to disable) ────────────────────────
SENTRY_DSN=
