# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://greenbond:password@localhost:5432/greenbonds
POSTGRES_USER=greenbond
POSTGRES_PASSWORD=password
POSTGRES_DB=greenbonds

# ── REDIS / CELERY ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── APP ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-something-long-and-random-in-production
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── BLOCKCHAIN (Polygon) ───────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_NEVER_COMMIT_THIS
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── NASA POWER API ─────────────────────────────────────────────────────────────
# No key required. Free public API.
NASA_API_BASE=https://power.larc.nasa.gov/api/temporal/daily/point
NASA_COMMUNITY=RE
NASA_PARAMETER=ALLSKY_SFC_SW_DWN

# ── TWILIO (SMS) ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── SENDGRID (Email) ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── CELERY SCHEDULE ────────────────────────────────────────────────────────────
CELERY_TIMEZONE=Asia/Kolkata
AUDIT_CRON_HOUR=6
AUDIT_CRON_MINUTE=0

# ── PR ENGINE ──────────────────────────────────────────────────────────────────
PR_THRESHOLD=0.75
CONSECUTIVE_PENALTY_DAYS=3
CONSECUTIVE_RECOVERY_DAYS=7
PERFORMANCE_FACTOR=0.80
PENALTY_RATE_MULTIPLIER=1.5
